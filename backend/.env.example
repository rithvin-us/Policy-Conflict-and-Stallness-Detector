# Copy to .env and adjust. All values have safe local defaults.

# Database — SQLite by default; point at Postgres or SingleStore in production.
# Postgres:    DATABASE_URL=postgresql+psycopg://policy:policy@localhost:5432/policyguardian
# SingleStore: DATABASE_URL=singlestoredb://<user>:<password>@<host>:3306/policyguardian?ssl_disabled=False
#   (a bare postgres://, postgresql://, or singlestore:// scheme is auto-normalized to the right driver)
DATABASE_URL=sqlite:///./policyguardian.db

# Async workers (optional). Leave USE_CELERY=0 for synchronous in-process runs.
USE_CELERY=0
REDIS_URL=redis://localhost:6379/0

# Seed the sample policy corpus on first boot.
SEED_ON_STARTUP=1
# SEED_POLICY_DIR=../sample_data/policies

# Deterministic staleness reference date (YYYY-MM-DD). Empty = today().
ANALYSIS_AS_OF=2026-07-11

# Optional GitHub connector token (never persisted to the DB).
# GITHUB_TOKEN=ghp_xxx

# Shared secret for verifying inbound GitHub webhook signatures (HMAC-SHA256).
# Set the same value in the GitHub webhook config. Empty = signature check off.
# GITHUB_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Outbound compliance-manager notification webhook (optional).
# NOTIFY_WEBHOOK_URL=https://hooks.example.com/policy-guardian

# Enable the optional embeddings similarity layer (requires requirements-ml.txt).
POLICYGUARDIAN_USE_EMBEDDINGS=0

# Frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
